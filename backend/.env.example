# Copy this file to `.env` in the same folder (backend/) and fill in values.
# `.env` is gitignored.

# Emails (registration welcome, login notice, appeal updates, internship/placement status changes):
# Require MAIL_SERVER + MAIL_USERNAME + MAIL_PASSWORD for authenticated SMTP (e.g. Gmail app password).
# MAIL_DEFAULT_SENDER can be omitted; it defaults to MAIL_USERNAME.

# MAIL_PASSWORD = Gmail app password (16 chars, no spaces) — not your normal password
# MAIL_SERVER = SMTP host only (never your Gmail address here)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
# If port 587 is blocked, use instead: MAIL_USE_SSL=true  MAIL_PORT=465  MAIL_USE_TLS=false
MAIL_USE_SSL=false
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=your.email@gmail.com

# React app URL for password-reset links (no trailing slash)
FRONTEND_URL=http://localhost:5173
# PASSWORD_RESET_EXPIRATION_MINUTES=60
